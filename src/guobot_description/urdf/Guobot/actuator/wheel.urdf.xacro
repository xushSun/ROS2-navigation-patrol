<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Guobot">
    <xacro:include filename="$(find demo_cpp_slam)/urdf/Guobot/common_inertia.urdf.xacro"/>
    <xacro:macro name = "wheel_xacro" params = "wheel_name xyz">
        <link name="${wheel_name}_wheel_link">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <geometry>
                    <cylinder radius="0.04" length="0.032"/>
                </geometry>
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <geometry>
                    <cylinder radius="0.04" length="0.032"/>
                </geometry>
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </collision>
            <xacro:cylinder_inertia m = "0.2" r = "0.04" h = "0.032"/>
        </link>
        <joint name="${wheel_name}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${wheel_name}_wheel_link"/>
            <origin xyz="${xyz}"/>
            <axis xyz="0.0 1 0.0"/>
        </joint>
        <gazebo reference = "${wheel_name}_wheel_link">
            <material>
                Gazebo/Yellow
            </material>
            <mu1 value = "20.0"/>
            <mu2 value = "20.0"/>
            <kp value = "1000000000.0"/>
            <kd value = "1.0"/>
        </gazebo>
    </xacro:macro>
</robot>